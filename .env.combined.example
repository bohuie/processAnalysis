# ============================================================
# COMBINED WORKFLOW ENVIRONMENT FILE
# Used by: processAnalysis/run-combined-report.sh
#
# This file is the single source of truth for the combined
# processAnalysis + collabAnalysis report workflow.
# It contains everything both repos need, including which
# GitHub repos to pull so both pipelines target the same data.
#
# Fill in your values and run:
#   ./run-combined-report.sh
# ============================================================


# ============================================================
# GITHUB AUTHENTICATION (used by both PA and CA)
# ============================================================
# Personal access token with repo read access to REPO_OWNER.
# Both PA and CA use the same env var name (GITHUB_TOKEN).
GITHUB_TOKEN=your-github-token-here


# ============================================================
# PROCESS ANALYSIS (PA) CONFIG
# ============================================================
AI_MODE=offline
GROQ_API_KEY=
API_KEY=dev-secret-key


# ============================================================
# COLLAB ANALYSIS (CA) CONFIG
# ============================================================
# wkhtmltopdf is pre-installed in the CA Docker image at this path.
PATH_TO_WKHTMLTOPDF=/usr/bin/wkhtmltopdf


# ============================================================
# TARGET REPOS — defines what BOTH PA and CA pull
# ============================================================
# GitHub organisation or user that owns all target repos.
REPO_OWNER=COSC-499-W2023

# Comma-separated list of repository names (no spaces around commas).
# Both PA (extraction + process model) and CA (GitHub data extraction)
# will target exactly these repos.
REPO_NAMES=year-long-project-team-1,year-long-project-team-2

# Date range for CA GitHub data extraction (ISO 8601).
START_DATE=2023-09-01T00:00:00Z
END_DATE=2024-04-30T23:59:59Z
